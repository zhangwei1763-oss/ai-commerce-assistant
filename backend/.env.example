# ===== 豆包API配置 =====
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-202502xxxxx
ARK_MODEL=
ARK_TEXT_MODEL=ep-20260225204603-zcqr4
ARK_VIDEO_MODEL=ep-20260225204954-4sqgz
ARK_TEXT_TEST_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/responses
ARK_VIDEO_TEST_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks

# ===== Seedance API配置 =====
SEEDANCE_API_KEY=your_seedance_api_key
SEEDANCE_API_URL=https://api.seedance.com/v1

# ===== 存储路径 =====
STORAGE_BACKEND=local
STORAGE_PUBLIC_BASE_URL=
STORAGE_DIR=./storage
VIDEO_DIR=./storage/videos
IMAGE_DIR=./storage/images
EXPORT_DIR=./storage/exports
TEMP_DIR=./storage/tmp

# Supabase Storage（当 STORAGE_BACKEND=supabase 时启用）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=ai-douyin-helper

# ===== 数据库 =====
# 本地开发（SQLite）
DATABASE_URL=sqlite:///./ai_douyin_helper.db

# Supabase 部署示例（Postgres / SQLAlchemy）
# DATABASE_URL=postgresql+psycopg://postgres.xxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# ===== 安全配置 =====
SECRET_KEY=replace_with_a_long_random_secret
API_KEY_ENCRYPTION_KEY=replace_with_a_long_random_encryption_key
BOOTSTRAP_ADMIN_CARD_KEY=ADMN-8888-9999-AAAA
BOOTSTRAP_ADMIN_CARD_NAME=系统管理员

# ===== CORS =====
CORS_ORIGINS=["http://localhost:5173","http://localhost:1420","http://localhost:3000","https://your-frontend.vercel.app"]

# ===== 邮件验证码（SMTP）=====
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI带货助手
SMTP_USE_TLS=false
SMTP_USE_SSL=true
