# ===== 最小必填项 =====
# docker-compose.cn.yml 默认会启动 postgres 服务，容器间地址直接填 postgres
DATABASE_URL=postgresql+psycopg://ai_commerce:change_me_now@postgres:5432/ai_commerce
SECRET_KEY=replace_with_a_long_random_secret
API_KEY_ENCRYPTION_KEY=replace_with_a_long_random_encryption_key
CORS_ORIGINS=["https://your-domain.com","http://your-server-ip"]

# ===== AI 相关（当前主流程可选）=====
# 这套系统当前主流程支持“用户登录后自行填写并保存 API Key”。
# 因此部署时可以先不填 DOUBAO_API_KEY / SEEDANCE_API_KEY，系统仍能启动；
# 只是用户在页面里未配置自己的 Key 前，AI 生成功能不可用。
DOUBAO_API_KEY=
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-202502xxxxx
ARK_MODEL=
ARK_TEXT_MODEL=ep-20260225204603-zcqr4
ARK_VIDEO_MODEL=ep-20260225204954-4sqgz
ARK_TEXT_TEST_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/responses
ARK_VIDEO_TEST_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks

SEEDANCE_API_KEY=
SEEDANCE_API_URL=https://api.seedance.com/v1

# ===== 存储 =====
STORAGE_BACKEND=local
STORAGE_PUBLIC_BASE_URL=
STORAGE_DIR=/app/storage
VIDEO_DIR=/app/storage/videos
IMAGE_DIR=/app/storage/images
EXPORT_DIR=/app/storage/exports
TEMP_DIR=/app/storage/tmp

# ===== Supabase Storage（可选）=====
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=ai-douyin-helper

# ===== 邮件验证码（可选）=====
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI带货助手
SMTP_USE_TLS=false
SMTP_USE_SSL=true

# ===== 阿里云短信（可选）=====
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
